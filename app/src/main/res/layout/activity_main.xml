<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/back_ele"
    >


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/next_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/border_20_stroke"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"
        >

        <TextView
            android:id="@+id/d_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/day_expre"
            android:text="DAY"
            android:fontFamily="@font/p_p"
            android:textColor="@color/green_p_p"
            android:textSize="20dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            />

        <TextView
            android:id="@+id/day_expre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/d_info"
            android:text="30"
            android:fontFamily="@font/p_p"
            android:textColor="@color/green_p_p"
            android:textSize="18dp"
            android:layout_marginEnd="20dp"
            android:layout_marginStart="20dp"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/next_day"
        app:layout_constraintBottom_toBottomOf="@id/next_day"
        app:layout_constraintStart_toEndOf="@id/next_day"
        app:layout_constraintEnd_toStartOf="@id/search"
        android:textSize="50dp"
        android:fontFamily="@font/name_f_p_p"
        android:textColor="@color/yellow_p_p"
        android:maxLength="7"
        />

    <SearchView
        android:id="@+id/search"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:maxWidth="150dp"
        />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recy_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/search"
        android:layout_marginTop="10dp"
        />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/back_global_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/recy_count"
        android:layout_marginTop="20dp"
        android:background="@drawable/border"
        android:backgroundTint="@color/back_p_p"
        >

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/pass_image"
            android:layout_width="80dp"
            android:layout_height="100dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            />

        <TextView
            android:id="@+id/global_misio"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/pass_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/pass_image"
            android:layout_marginEnd="10dp"
            android:layout_marginStart="10dp"
            android:textColor="@color/text_color"
            android:fontFamily="@font/p_p"
            android:text="Check daily bulletin for wanted criminals"
            android:textSize="15dp"
            android:gravity="center"
            />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/seal_1"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:layout_constraintTop_toBottomOf="@id/pass_image"
            app:layout_constraintStart_toStartOf="@id/pass_image"
            app:layout_constraintEnd_toStartOf="@id/seal_2"
            android:layout_marginTop="10dp"
            />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/seal_2"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:layout_constraintTop_toBottomOf="@id/pass_image"
            app:layout_constraintEnd_toEndOf="@id/pass_image"
            app:layout_constraintStart_toEndOf="@id/seal_1"
            android:layout_marginTop="10dp"
            />


        <TextView
            android:id="@+id/text_seals"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/seal_1"
            app:layout_constraintTop_toBottomOf="@id/global_misio"
            app:layout_constraintBottom_toBottomOf="@id/pass_image"
            android:text="valid stamps"
            android:fontFamily="@font/p_p"
            android:textColor="@color/title_color"
            android:textSize="18dp"
        />
        <View
            android:id="@+id/sepa_t_s"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@color/ele_color"
            app:layout_constraintEnd_toEndOf="@id/text_seals"
            app:layout_constraintStart_toStartOf="@id/text_seals"
            app:layout_constraintTop_toBottomOf="@id/text_seals"
            android:layout_marginTop="5dp"
            />

        <View
            android:id="@+id/sepa_seal"
            android:layout_width="4dp"
            android:layout_height="70dp"
            android:background="@color/ele_color"
            app:layout_constraintTop_toBottomOf="@id/sepa_t_s"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/sepa_t_s"
            app:layout_constraintEnd_toEndOf="@id/sepa_t_s"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/e_s_1"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/entry_s_1"
            app:layout_constraintTop_toTopOf="@id/sepa_seal"
            app:layout_constraintEnd_toStartOf="@id/e_s_2"
            android:layout_marginEnd="10dp"
            />
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/e_s_2"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/entry_s_2"
            app:layout_constraintTop_toTopOf="@id/sepa_seal"
            app:layout_constraintEnd_toStartOf="@id/sepa_seal"
            android:layout_marginEnd="10dp"
            />


        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/w_s_1"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/work_s_1"
            app:layout_constraintTop_toTopOf="@id/sepa_seal"
            app:layout_constraintStart_toEndOf="@id/sepa_seal"
            android:layout_marginStart="10dp"
            />
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/w_s_2"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/work_s_2"
            app:layout_constraintTop_toTopOf="@id/sepa_seal"
            app:layout_constraintStart_toEndOf="@id/w_s_1"
            android:layout_marginStart="10dp"
            />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/w_s_3"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/work_s_3"
            app:layout_constraintTop_toBottomOf="@id/w_s_1"
            app:layout_constraintStart_toEndOf="@id/sepa_seal"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            />
        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/work_s_4"
            app:layout_constraintTop_toBottomOf="@id/w_s_2"
            app:layout_constraintStart_toEndOf="@id/w_s_3"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            />



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/back_day_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/back_global_info"
        app:layout_constraintEnd_toEndOf="@id/back_cons_misions"
        app:layout_constraintStart_toStartOf="@id/back_cons_misions"
        android:layout_marginTop="10dp"
        android:background="@drawable/border"
        android:backgroundTint="@color/back_p_p"
        >

        <TextView
            android:id="@+id/day_misio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/war_al"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginEnd="10dp"
            android:textColor="@color/text_color"
            android:fontFamily="@font/p_p"
            android:text="Seize passports"
            android:textSize="15dp"
            android:gravity="center"
            android:maxWidth="300dp"
            />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/war_al"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/warning"
            app:layout_constraintTop_toTopOf="@id/day_misio"
            app:layout_constraintBottom_toBottomOf="@id/day_misio"
            app:layout_constraintEnd_toStartOf="@id/day_misio"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/back_cons_misions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_day_info"
        android:layout_marginTop="10dp"
        android:background="@drawable/border"
        android:backgroundTint="@color/back_p_p"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="10dp"
        >

        <TextView
            android:id="@+id/cons_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="5dp"
            android:layout_marginStart="5dp"
            android:text="Regulation"
            android:fontFamily="@font/p_p"
            android:textColor="@color/title_color"
            android:textSize="18dp"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cons_misions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/cons_info"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:overScrollMode="never"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/back_city"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/back_cons_misions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/border"
        android:backgroundTint="@color/back_p_p"
        >

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recy_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:overScrollMode="never"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/new_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/add_notes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="20dp"
        />

    <TextView
        android:id="@+id/country_actu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/new_note"
        app:layout_constraintBottom_toBottomOf="@id/new_note"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:text="United Federation"
        android:textColor="@color/back_p_p"
        android:fontFamily="@font/p_p"
        android:textSize="17dp"
        />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/idea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/feed_back"
        />


</androidx.constraintlayout.widget.ConstraintLayout>